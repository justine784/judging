rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /contestants/{contestantId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /judges/{judgeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /scores/{scoreId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /slideSubmissions/{submissionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /passwordResets/{resetId} {
      allow read, write: if true;
    }
  }
}
