rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/judges/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isJudge() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/judges/$(request.auth.uid)).data.role == 'judge';
    }
    
    // More permissive check for managescore page
    function isManageScoreUser() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/judges/$(request.auth.uid)).data.email == 'managescore@gmail.com';
    }

    // CONTESTANTS COLLECTION - Allow judges to write for score submissions
    match /contestants/{id} {
      // Read access for everyone (including public for live scoreboard)
      allow read, get: if true;
      
      // Write access for admins and judges (for score submissions)
      allow write, create, update: if isAdmin() || isJudge();
      
      // Allow list access for real-time listeners
      allow list: if true;
    }

    // EVENTS COLLECTION
    match /events/{id} {
      // Read access for everyone (including public for live scoreboard)
      allow read, get: if true;
      
      // Write access for admins only
      allow write, create: if isAdmin();
      
      // Judges can update some fields like currentRound
      allow update: if isJudge() && 
                   request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentRound', 'status']);
      
      // Allow list access for real-time listeners
      allow list: if true;
    }

    // JUDGES COLLECTION
    match /judges/{id} {
      // Read access for authenticated users
      allow read, get: if isAuthenticated();
      
      // Write access for admins only
      allow write, create: if isAdmin();
      
      // Judges can update their own profile
      allow update: if isAuthenticated() && 
                   request.auth.uid == id;
      
      // Allow list access for real-time listeners
      allow list: if isAuthenticated() || isManageScoreUser();
    }

    // SCORES COLLECTION - Critical for score submission
    match /scores/{id} {
      // Read access for all authenticated users
      allow read, get: if isAuthenticated();
      
      // Write access for judges submitting scores with proper validation
      allow create, update: if isJudge() && 
                   request.resource.data.judgeId == request.auth.uid &&
                   request.resource.data.keys().hasAll(['eventId', 'contestantId', 'judgeId', 'timestamp', 'scores']) &&
                   request.resource.data.scores is map;
      
      // Admin can write any score
      allow write, create, update: if isAdmin();
      
      // Allow list access for real-time listeners (less restrictive for managescore page)
      allow list: if isAuthenticated() || isManageScoreUser();
    }

    // SLIDE SUBMISSIONS COLLECTION
    match /slideSubmissions/{id} {
      // Read access for all authenticated users
      allow read, get: if isAuthenticated();
      
      // Write access for judges submitting slide scores
      allow create, update: if isJudge() && 
                   request.resource.data.judgeId == request.auth.uid &&
                   request.resource.data.keys().hasAll(['eventId', 'contestantId', 'judgeId', 'submittedAt', 'scores']);
      
      // Admin can write any slide submission
      allow write, create, update: if isAdmin();
      
      // Allow list access for real-time listeners
      allow list: if isAuthenticated();
    }

    // PASSWORD RESETS COLLECTION
    match /passwordResets/{id} {
      allow read, write, get, create, update: if true;
    }

    // LIVE SCOREBOARD DATA (if you have this collection)
    match /liveScoreboard/{id} {
      allow read, get: if true;
      allow write, create, update: if isAdmin() || isJudge();
    }

    // EVENT SETTINGS
    match /eventSettings/{id} {
      allow read, get: if isAuthenticated();
      allow write, create, update: if isAdmin();
    }
  }
}
